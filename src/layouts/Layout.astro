---
import '../styles/global.css';

const {
  title = 'DRIP — Software Atelier Indonesia | UMKM, Korporasi, Pemerintah',
  description = 'Software atelier Indonesia. Kami menulis kode untuk UMKM, korporasi, dan instansi pemerintah. 11+ tahun pengalaman, 100% kode milik klien.',
  image
} = Astro.props;

const siteUrl = 'https://drip.id';
const canonicalUrl = siteUrl + Astro.url.pathname;
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <meta name="theme-color" content="#F4EFE6" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="DRIP" />
    <meta property="og:locale" content="id_ID" />
    {image && <meta property="og:image" content={image} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="min-h-screen flex flex-col relative">
    <a href="#main-content" class="skip-to-content">Lewati ke konten</a>

    <!-- =================== MASTHEAD HEADER =================== -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-[var(--paper)]/90 backdrop-blur-md border-b border-[var(--line)]">
      <!-- Top ticker -->
      <div class="hidden md:block border-b border-[var(--line-soft)] bg-[var(--paper-deep)]">
        <div class="max-w-7xl mx-auto px-6 py-1.5 flex items-center justify-between text-[10px] font-mono uppercase tracking-[0.18em] text-[var(--ink-mute)]">
          <span>Edisi 2026 · Vol. 01</span>
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--emerald-bright)] animate-pulse-dot"></span>
            <span>Available · Q1 2026</span>
          </span>
          <span>Beroperasi dari Yogyakarta · Melayani seluruh Indonesia</span>
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-6">
        <div class="flex items-center justify-between h-16 md:h-20">
          <!-- Logo / Masthead -->
          <a href="/" class="flex items-baseline gap-3 group">
            <span class="font-serif text-3xl md:text-4xl text-[var(--ink)] leading-none tracking-tight">DRIP<span class="text-[var(--emerald)]">.</span></span>
            <span class="hidden sm:inline text-[10px] font-mono uppercase tracking-[0.18em] text-[var(--ink-mute)] border-l border-[var(--line)] pl-3">Software Atelier</span>
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden lg:flex items-center gap-9 text-sm text-[var(--ink-soft)]">
            <a href="#klien" class="hover:text-[var(--emerald)] transition relative group">
              Klien
              <span class="absolute -bottom-1 left-0 right-0 h-px bg-[var(--emerald)] scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </a>
            <a href="#pekerjaan" class="hover:text-[var(--emerald)] transition relative group">
              Pekerjaan
              <span class="absolute -bottom-1 left-0 right-0 h-px bg-[var(--emerald)] scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </a>
            <a href="#proses" class="hover:text-[var(--emerald)] transition relative group">
              Proses
              <span class="absolute -bottom-1 left-0 right-0 h-px bg-[var(--emerald)] scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </a>
            <a href="#karya" class="hover:text-[var(--emerald)] transition relative group">
              Karya
              <span class="absolute -bottom-1 left-0 right-0 h-px bg-[var(--emerald)] scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </a>
            <a href="#tarif" class="hover:text-[var(--emerald)] transition relative group">
              Tarif
              <span class="absolute -bottom-1 left-0 right-0 h-px bg-[var(--emerald)] scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </a>
            <a href="#faq" class="hover:text-[var(--emerald)] transition relative group">
              Tanya
              <span class="absolute -bottom-1 left-0 right-0 h-px bg-[var(--emerald)] scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </a>
          </nav>

          <!-- Right side -->
          <div class="flex items-center gap-3">
            <a
              href="#kontak"
              class="hidden md:inline-flex items-center gap-2 bg-[var(--ink)] text-[var(--paper)] text-sm font-medium px-5 py-2.5 rounded-full hover:bg-[var(--emerald)] transition group"
            >
              Mulai Proyek
              <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>

            <!-- Mobile menu button -->
            <button
              id="mobile-menu-btn"
              class="lg:hidden p-2 text-[var(--ink)] hover:text-[var(--emerald)] transition"
              aria-label="Buka menu"
            >
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="3" y1="7" x2="21" y2="7"/>
                <line x1="3" y1="13" x2="21" y2="13"/>
                <line x1="3" y1="19" x2="21" y2="19"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden lg:hidden border-t border-[var(--line)] bg-[var(--paper)]">
        <nav class="flex flex-col px-6 py-4">
          {['Klien', 'Pekerjaan', 'Proses', 'Karya', 'Tarif', 'Tanya', 'Kontak'].map((item) => (
            <a
              href={`#${item.toLowerCase().replace(' ', '')}`}
              class="text-sm text-[var(--ink-soft)] hover:text-[var(--emerald)] transition py-3 border-b border-[var(--line-soft)] last:border-b-0"
            >
              {item}
            </a>
          ))}
          <a
            href="#kontak"
            class="mt-4 inline-flex items-center justify-center gap-2 bg-[var(--ink)] text-[var(--paper)] text-sm font-medium px-5 py-3 rounded-full"
          >
            Mulai Proyek →
          </a>
        </nav>
      </div>
    </header>

    <main id="main-content" class="flex-1 relative z-10 pt-16 md:pt-[104px]">
      <slot />
    </main>

    <!-- =================== COLOPHON FOOTER =================== -->
    <footer class="relative z-10 bg-[var(--ink)] text-[var(--paper)] mt-32">
      <!-- Decorative large type -->
      <div class="absolute top-0 left-0 right-0 overflow-hidden pointer-events-none opacity-[0.04]">
        <div class="font-serif text-[clamp(8rem,22vw,18rem)] leading-none tracking-tighter text-[var(--paper)] whitespace-nowrap -translate-y-1/4">
          DRIP · DRIP · DRIP
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-6 py-20 relative">
        <div class="grid md:grid-cols-12 gap-12 mb-16">
          <!-- Big statement -->
          <div class="md:col-span-7">
            <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--paper)]/50 mb-6">// Kolofon</div>
            <p class="font-serif text-3xl md:text-4xl leading-[1.15] tracking-tight text-[var(--paper)] mb-8">
              Sebuah atelier perangkat lunak kecil di Indonesia. Kami menulis kode untuk bisnis yang ingin <em class="text-[var(--gold)]">benar-benar berjalan.</em>
            </p>
            <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-[var(--paper)]/60">
              <a href="https://wa.me/62859106956390" target="_blank" rel="noopener" class="hover:text-[var(--gold)] transition flex items-center gap-2">
                <span class="font-mono">WA</span> 0859-1069-563-90
              </a>
              <span class="text-[var(--paper)]/20">·</span>
              <a href="mailto:maulana@drip.id" class="hover:text-[var(--gold)] transition font-mono">maulana@drip.id</a>
              <span class="text-[var(--paper)]/20">·</span>
              <span class="font-mono">Yogyakarta, ID</span>
            </div>
          </div>

          <!-- Site map -->
          <div class="md:col-span-3 md:col-start-10">
            <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--paper)]/50 mb-4">Peta Situs</div>
            <ul class="space-y-2 text-sm text-[var(--paper)]/80">
              <li><a href="#klien" class="hover:text-[var(--gold)] transition">Klien</a></li>
              <li><a href="#pekerjaan" class="hover:text-[var(--gold)] transition">Pekerjaan</a></li>
              <li><a href="#proses" class="hover:text-[var(--gold)] transition">Proses</a></li>
              <li><a href="#karya" class="hover:text-[var(--gold)] transition">Karya</a></li>
              <li><a href="#tarif" class="hover:text-[var(--gold)] transition">Tarif</a></li>
              <li><a href="#faq" class="hover:text-[var(--gold)] transition">Tanya</a></li>
            </ul>
          </div>
        </div>

        <!-- Spec strip -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 py-10 border-t border-[var(--paper)]/10">
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--paper)]/40 mb-1.5">Didirikan</div>
            <div class="font-serif text-xl text-[var(--paper)]">2015</div>
          </div>
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--paper)]/40 mb-1.5">Pengalaman</div>
            <div class="font-serif text-xl text-[var(--paper)]">11+ tahun</div>
          </div>
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--paper)]/40 mb-1.5">Projek</div>
            <div class="font-serif text-xl text-[var(--paper)]">50+ selesai</div>
          </div>
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--paper)]/40 mb-1.5">Kepemilikan</div>
            <div class="font-serif text-xl text-[var(--gold)]">100% klien</div>
          </div>
        </div>

        <!-- Bottom -->
        <div class="pt-8 border-t border-[var(--paper)]/10 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-xs text-[var(--paper)]/40 font-mono">
          <p>© 2026 PT. DRIP RINTISAN INOVASI PERKASA · NPWP 39.474.371.0-732.000</p>
          <p>Press <kbd class="px-1.5 py-0.5 border border-[var(--paper)]/20 rounded text-[var(--paper)]/60">Esc</kbd> to breathe.</p>
        </div>
      </div>
    </footer>

    <!-- Back to top -->
    <button
      id="back-to-top"
      class="fixed bottom-6 right-6 z-40 bg-[var(--ink)] text-[var(--paper)] p-3 rounded-full shadow-lg hover:bg-[var(--emerald)] transition opacity-0 pointer-events-none"
      aria-label="Kembali ke atas"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
    </button>

    <script>
      const menuBtn = document.getElementById("mobile-menu-btn");
      const mobileMenu = document.getElementById("mobile-menu");

      menuBtn?.addEventListener("click", () => {
        mobileMenu?.classList.toggle("hidden");
      });

      mobileMenu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu.classList.add("hidden");
        });
      });

      const backToTop = document.getElementById('back-to-top');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 600) {
          backToTop?.classList.remove('opacity-0', 'pointer-events-none');
        } else {
          backToTop?.classList.add('opacity-0', 'pointer-events-none');
        }
      });
      backToTop?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    </script>
  </body>
</html>
