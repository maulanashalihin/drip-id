---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="DRIP — Software Atelier Indonesia | UMKM, Korporasi, Pemerintah"
  description="Software atelier Indonesia. Kami menulis kode untuk UMKM, korporasi, dan instansi pemerintah. 11+ tahun pengalaman, 100% kode milik klien."
>

  <!-- =================== COVER / HERO =================== -->
  <section class="relative max-w-7xl mx-auto px-6 pt-12 md:pt-20 pb-24 md:pb-32">
    <!-- Top metadata strip -->
    <div class="flex items-center justify-between mb-12 md:mb-16 font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--ink-mute)]">
      <span>Edisi 2026 · Vol. 01</span>
      <span class="hidden md:inline">— Sebuah Software Atelier</span>
      <span class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--emerald-bright)] animate-pulse-dot"></span>
        Menerima klien baru
      </span>
    </div>

    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      <!-- LEFT: Massive headline -->
      <div class="lg:col-span-8">
        <div class="inline-flex items-center gap-2 stamp stamp-emerald mb-10">
          <span class="w-1.5 h-1.5 bg-[var(--emerald)] rounded-full"></span>
          Software Atelier · Indonesia
        </div>

        <h1 class="font-serif text-[clamp(2.75rem,7.5vw,6rem)] leading-[0.95] tracking-tight text-[var(--ink)] mb-10">
          Perangkat lunak<br/>
          untuk bisnis yang<br/>
          <em class="text-[var(--emerald)] not-italic">sedang bergerak</em><span class="text-[var(--ink)]">.</span>
        </h1>

        <p class="text-lg md:text-xl text-[var(--ink-soft)] leading-[1.55] max-w-2xl mb-10">
          Kami adalah <span class="underline-mark">atelier kecil</span> yang menulis perangkat lunak untuk UMKM, korporasi, dan instansi pemerintah di seluruh Indonesia. Bukan sekadar bikin tampilan — kami bangun sistem yang benar-benar bekerja untuk bisnis Anda.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center mb-14">
          <a
            href="#kontak"
            class="inline-flex items-center gap-3 bg-[var(--ink)] text-[var(--paper)] text-base font-medium px-7 py-4 rounded-full hover:bg-[var(--emerald)] transition group"
          >
            Mulai Proyek Anda
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a
            href="#karya"
            class="inline-flex items-center gap-2 text-base text-[var(--ink)] hover:text-[var(--emerald)] transition group font-medium"
          >
            <span class="border-b border-[var(--ink)] group-hover:border-[var(--emerald)] pb-0.5">Lihat Karya</span>
            <span class="text-[var(--ink-mute)] group-hover:text-[var(--emerald)] font-serif italic text-lg">→</span>
          </a>
        </div>

        <!-- Credential line -->
        <div class="flex flex-wrap items-center gap-x-8 gap-y-3 text-sm text-[var(--ink-soft)] pt-8 border-t border-[var(--line)]">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[var(--emerald)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span><span class="font-serif text-lg text-[var(--ink)] mr-1">11+</span>tahun</span>
          </span>
          <span class="w-px h-5 bg-[var(--line)]"></span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[var(--emerald)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span><span class="font-serif text-lg text-[var(--ink)] mr-1">50+</span>projek selesai</span>
          </span>
          <span class="w-px h-5 bg-[var(--line)]"></span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[var(--emerald)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span><span class="font-serif text-lg text-[var(--emerald)] mr-1">100%</span>kode milik Anda</span>
          </span>
        </div>
      </div>

      <!-- RIGHT: Spec card -->
      <div class="lg:col-span-4 lg:sticky lg:top-32">
        <div class="spec-card p-7 rounded-2xl">
          <div class="flex items-start justify-between mb-5">
            <div>
              <div class="font-mono text-[9px] uppercase tracking-[0.22em] text-[var(--ink-mute)] mb-1">FACT SHEET</div>
              <div class="font-serif text-2xl text-[var(--ink)] leading-tight">DRIP<span class="text-[var(--emerald)]">.</span></div>
            </div>
            <div class="text-right">
              <div class="font-mono text-[9px] uppercase tracking-[0.22em] text-[var(--ink-mute)]">No.</div>
              <div class="font-serif text-lg text-[var(--ink)]">001</div>
            </div>
          </div>

          <dl class="space-y-3 text-sm">
            <div class="flex justify-between items-baseline pb-2 border-b border-dashed border-[var(--line)]">
              <dt class="font-mono text-[10px] uppercase tracking-wider text-[var(--ink-mute)]">Didirikan</dt>
              <dd class="font-serif text-[var(--ink)]">2015</dd>
            </div>
            <div class="flex justify-between items-baseline pb-2 border-b border-dashed border-[var(--line)]">
              <dt class="font-mono text-[10px] uppercase tracking-wider text-[var(--ink-mute)]">Bentuk</dt>
              <dd class="text-[var(--ink)]">Atelier solo</dd>
            </div>
            <div class="flex justify-between items-baseline pb-2 border-b border-dashed border-[var(--line)]">
              <dt class="font-mono text-[10px] uppercase tracking-wider text-[var(--ink-mute)]">Lokasi</dt>
              <dd class="text-[var(--ink)]">Yogyakarta</dd>
            </div>
            <div class="flex justify-between items-baseline pb-2 border-b border-dashed border-[var(--line)]">
              <dt class="font-mono text-[10px] uppercase tracking-wider text-[var(--ink-mute)]">Wilayah</dt>
              <dd class="text-[var(--ink)]">Seluruh Indonesia</dd>
            </div>
            <div class="flex justify-between items-baseline pb-2 border-b border-dashed border-[var(--line)]">
              <dt class="font-mono text-[10px] uppercase tracking-wider text-[var(--ink-mute)]">Klien</dt>
              <dd class="text-[var(--ink)]">UMKM · Korporasi · Govt</dd>
            </div>
            <div class="flex justify-between items-baseline pb-2 border-b border-dashed border-[var(--line)]">
              <dt class="font-mono text-[10px] uppercase tracking-wider text-[var(--ink-mute)]">Bahasa</dt>
              <dd class="text-[var(--ink)]">Indonesia, English</dd>
            </div>
            <div class="flex justify-between items-baseline pb-2 border-b border-dashed border-[var(--line)]">
              <dt class="font-mono text-[10px] uppercase tracking-wider text-[var(--ink-mute)]">Standar</dt>
              <dd class="text-[var(--emerald)] font-medium">SPBE · OWASP</dd>
            </div>
            <div class="flex justify-between items-baseline">
              <dt class="font-mono text-[10px] uppercase tracking-wider text-[var(--ink-mute)]">IP</dt>
              <dd class="text-[var(--emerald)] font-medium">100% klien</dd>
            </div>
          </dl>

          <div class="mt-6 pt-5 border-t border-[var(--line)] text-[11px] text-[var(--ink-mute)] leading-relaxed font-mono">
            <span class="text-[var(--emerald)]">▸</span> Jangan ragu bertanya, kami akan jujur kalau bukan proyek yang tepat untuk kami.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- =================== 01 · KLIEN =================== -->
  <section id="klien" class="relative max-w-7xl mx-auto px-6 py-24 md:py-32">
    <!-- Section header -->
    <div class="grid lg:grid-cols-12 gap-8 mb-16 md:mb-20">
      <div class="lg:col-span-2">
        <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--ink-mute)] mb-2">Bagian</div>
        <div class="font-serif text-7xl text-[var(--emerald)] leading-none">01</div>
      </div>
      <div class="lg:col-span-10">
        <h2 class="font-serif text-4xl md:text-6xl tracking-tight text-[var(--ink)] leading-[1.05] mb-6">
          Tiga klien. <em class="text-[var(--emerald)]">Satu standar.</em>
        </h2>
        <p class="text-lg md:text-xl text-[var(--ink-soft)] leading-[1.55] max-w-3xl">
          Apapun ukuran Anda — dari warung kelontong di Sulawesi sampai kementerian di Jakarta — kami layani dengan standar engineering yang sama. <span class="underline-mark">Tidak ada kelas dua.</span>
        </p>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <!-- UMKM -->
      <article class="group relative bg-[var(--paper-elevated)] border border-[var(--line)] p-8 rounded-2xl hover:border-[var(--emerald)] transition overflow-hidden">
        <div class="absolute top-0 right-0 font-serif text-7xl text-[var(--emerald)]/8 leading-none p-4">α</div>
        <div class="relative">
          <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--ink-mute)] mb-6">Untuk UMKM</div>
          <h3 class="font-serif text-3xl text-[var(--ink)] leading-tight mb-4">Usaha Mikro, Kecil, Menengah<span class="text-[var(--emerald)]">.</span></h3>
          <p class="text-[var(--ink-soft)] leading-[1.6] text-[15px] mb-7">
            Solusi digital <em class="font-serif">terjangkau, cepat jadi, dan siap pakai.</em> Untuk pemilik usaha yang ingin go-online tanpa pusing urusan teknis.
          </p>
          <ul class="space-y-2.5 text-sm text-[var(--ink-soft)] mb-7">
            <li class="flex gap-3"><span class="text-[var(--emerald)] mt-0.5">→</span> Toko online & landing page</li>
            <li class="flex gap-3"><span class="text-[var(--emerald)] mt-0.5">→</span> Sistem kasir & inventory</li>
            <li class="flex gap-3"><span class="text-[var(--emerald)] mt-0.5">→</span> Integrasi QRIS & WhatsApp</li>
            <li class="flex gap-3"><span class="text-[var(--emerald)] mt-0.5">→</span> Training via Zoom included</li>
          </ul>
          <div class="pt-6 border-t border-dashed border-[var(--line)] flex items-baseline justify-between">
            <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--ink-mute)]">Mulai dari</span>
            <span class="font-serif text-2xl text-[var(--emerald)]">Rp 15 juta</span>
          </div>
        </div>
      </article>

      <!-- Korporasi -->
      <article class="group relative bg-[var(--ink)] text-[var(--paper)] p-8 rounded-2xl overflow-hidden">
        <div class="absolute top-0 right-0 font-serif text-7xl text-[var(--paper)]/8 leading-none p-4">β</div>
        <div class="absolute top-4 right-4 stamp" style="background: rgba(168, 138, 77, 0.15); border-color: var(--gold); color: var(--gold);">Paling Diminati</div>
        <div class="relative">
          <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--paper)]/50 mb-6">Untuk Korporasi</div>
          <h3 class="font-serif text-3xl leading-tight mb-4">Perusahaan Menengah & Besar<span class="text-[var(--gold)]">.</span></h3>
          <p class="text-[var(--paper)]/75 leading-[1.6] text-[15px] mb-7">
            Sistem <em class="font-serif">custom enterprise-grade</em> yang terintegrasi dengan workflow existing Anda. Skalabel, aman, siap di-audit.
          </p>
          <ul class="space-y-2.5 text-sm text-[var(--paper)]/75 mb-7">
            <li class="flex gap-3"><span class="text-[var(--gold)] mt-0.5">→</span> ERP, CRM, dashboard analytics</li>
            <li class="flex gap-3"><span class="text-[var(--gold)] mt-0.5">→</span> Integrasi API & middleware</li>
            <li class="flex gap-3"><span class="text-[var(--gold)] mt-0.5">→</span> SSO, RBAC, audit log</li>
            <li class="flex gap-3"><span class="text-[var(--gold)] mt-0.5">→</span> Dokumentasi teknis lengkap</li>
          </ul>
          <div class="pt-6 border-t border-dashed border-[var(--paper)]/15 flex items-baseline justify-between">
            <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--paper)]/50">Mulai dari</span>
            <span class="font-serif text-2xl text-[var(--gold)]">Rp 50 juta</span>
          </div>
        </div>
      </article>

      <!-- Pemerintah -->
      <article class="group relative bg-[var(--paper-elevated)] border border-[var(--line)] p-8 rounded-2xl hover:border-[var(--rust)] transition overflow-hidden">
        <div class="absolute top-0 right-0 font-serif text-7xl text-[var(--rust)]/8 leading-none p-4">γ</div>
        <div class="relative">
          <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--ink-mute)] mb-6">Untuk Pemerintah</div>
          <h3 class="font-serif text-3xl text-[var(--ink)] leading-tight mb-4">Kementerian, Pemda, BUMD<span class="text-[var(--rust)]">.</span></h3>
          <p class="text-[var(--ink-soft)] leading-[1.6] text-[15px] mb-7">
            Sistem informasi <em class="font-serif">SPBE-compliant</em>, hosted di PDN, sesuai regulasi. Berpengalaman e-procurement LKPP dan audit BPKP.
          </p>
          <ul class="space-y-2.5 text-sm text-[var(--ink-soft)] mb-7">
            <li class="flex gap-3"><span class="text-[var(--rust)] mt-0.5">→</span> Sistem informasi & e-government</li>
            <li class="flex gap-3"><span class="text-[var(--rust)] mt-0.5">→</span> SPBE · TKDN · PDN-ready</li>
            <li class="flex gap-3"><span class="text-[var(--rust)] mt-0.5">→</span> e-Procurement & kontrak LKPP</li>
            <li class="flex gap-3"><span class="text-[var(--rust)] mt-0.5">→</span> BAST & dokumentasi RFP</li>
          </ul>
          <div class="pt-6 border-t border-dashed border-[var(--line)] flex items-baseline justify-between">
            <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--ink-mute)]">Penawaran</span>
            <span class="font-serif text-2xl text-[var(--rust)]">via tender</span>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- =================== TRUST MARQUEE =================== -->
  <section class="border-y border-[var(--line)] bg-[var(--paper-deep)] py-7 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 flex items-center gap-10">
      <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--ink-mute)] whitespace-nowrap hidden md:block">Dipercaya oleh →</div>
      <div class="flex-1 overflow-hidden">
        <div class="flex items-center gap-12 whitespace-nowrap animate-marquee">
          {Array.from({length: 2}).map(() => (
            <div class="flex items-center gap-12 text-[var(--ink-soft)]">
              <span class="font-serif text-lg">100+ Masjid</span>
              <span class="text-[var(--ink-faint)]">◆</span>
              <span class="font-serif text-lg">Klinik & RS Swasta</span>
              <span class="text-[var(--ink-faint)]">◆</span>
              <span class="font-serif text-lg">UMKM Nasional</span>
              <span class="text-[var(--ink-faint)]">◆</span>
              <span class="font-serif text-lg">Startup B2B</span>
              <span class="text-[var(--ink-faint)]">◆</span>
              <span class="font-serif text-lg">Instansi Pemda</span>
              <span class="text-[var(--ink-faint)]">◆</span>
              <span class="font-serif text-lg">F&B & Retail</span>
              <span class="text-[var(--ink-faint)]">◆</span>
              <span class="font-serif text-lg">BUMD</span>
              <span class="text-[var(--ink-faint)]">◆</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- =================== 02 · PEKERJAAN =================== -->
  <section id="pekerjaan" class="relative max-w-7xl mx-auto px-6 py-24 md:py-32">
    <div class="grid lg:grid-cols-12 gap-8 mb-16">
      <div class="lg:col-span-2">
        <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--ink-mute)] mb-2">Bagian</div>
        <div class="font-serif text-7xl text-[var(--emerald)] leading-none">02</div>
      </div>
      <div class="lg:col-span-10">
        <h2 class="font-serif text-4xl md:text-6xl tracking-tight text-[var(--ink)] leading-[1.05] mb-6">
          Enam jenis pekerjaan<span class="text-[var(--ink-mute)]">.</span><br/>
          <em class="text-[var(--emerald)] text-3xl md:text-4xl">Satu standar mutu.</em>
        </h2>
        <p class="text-lg text-[var(--ink-soft)] leading-[1.55] max-w-2xl">
          Dari ide sampai production, kami handle semuanya. Anda fokus ke bisnis, kami yang urus teknologinya.
        </p>
      </div>
    </div>

    <div class="max-w-5xl">
      {[
        { n: '01', t: 'Aplikasi Custom', d: 'Web app, mobile app, dan dashboard internal. Dibangun dari nol sesuai workflow Anda — bukan template yang dipaksakan.', s: 'Web · Mobile · Dashboard' },
        { n: '02', t: 'AI Agent & Otomasi', d: 'Chatbot WhatsApp, workflow otomatis, dan analisis data. AI yang benar-benar bekerja, bukan gimmick yang ramai di Twitter.', s: 'LLM · RAG · Workflow' },
        { n: '03', t: 'Integrasi Sistem & API', d: 'Hubungkan sistem lama dengan yang baru. Payment gateway, accounting, marketplace, API pemerintah — semua bisa.', s: 'REST · Webhook · Middleware' },
        { n: '04', t: 'Konsultasi & Perencanaan', d: 'Pusing mulai dari mana? Kami bantu petakan: apa yang harus dibangun, urutan prioritas, dan estimasi biayanya.', s: 'Roadmap · Audit · Arsitektur' },
        { n: '05', t: 'Migrasi & Modernisasi', d: 'Sistem lama masih jalan tapi sudah berdebu? Kami migrasi ke stack modern tanpa downtime panjang.', s: 'Legacy · Cloud · Refactor' },
        { n: '06', t: 'Pemeliharaan & Support', d: 'Sistem sudah jadi? Kami jaga tetap jalan 24/7. Bug fix, update keamanan, monitoring server — handled.', s: 'Monitoring · Update · SLA' }
      ].map((item) => (
        <article class="editorial-item group hover:bg-[var(--paper-elevated)] transition -mx-4 px-4 rounded-xl">
          <div class="number">{item.n}</div>
          <div>
            <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-2">
              <h3 class="font-serif text-2xl md:text-3xl text-[var(--ink)] group-hover:text-[var(--emerald)] transition">{item.t}</h3>
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--ink-mute)]">{item.s}</span>
            </div>
            <p class="text-[var(--ink-soft)] leading-[1.6] max-w-2xl">{item.d}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- =================== 03 · PROSES =================== -->
  <section id="proses" class="bg-[var(--ink)] text-[var(--paper)] py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-8 mb-16 md:mb-20">
        <div class="lg:col-span-2">
          <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--paper)]/40 mb-2">Bagian</div>
          <div class="font-serif text-7xl text-[var(--gold)] leading-none">03</div>
        </div>
        <div class="lg:col-span-10">
          <h2 class="font-serif text-4xl md:text-6xl tracking-tight leading-[1.05] mb-6">
            Empat tahap<span class="text-[var(--paper)]/40">.</span><br/>
            <em class="text-[var(--gold)] text-3xl md:text-4xl">Tanpa rapat berlarut-larut.</em>
          </h2>
          <p class="text-lg text-[var(--paper)]/70 leading-[1.55] max-w-2xl">
            Tanpa Jira yang tidak ada habisnya. Tanpa meeting 2 jam tiap Jumat. Murni eksekusi asinkron yang terukur.
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-4 gap-px bg-[var(--paper)]/10">
        {[
          { n: 'I', t: 'Riset & Scope', d: 'Kita gali kebutuhan, kunci fitur utama, dan setujui anggaran di depan. Tidak ada kejutan di belakang.', time: 'Minggu 1' },
          { n: 'II', t: 'Bangun Mesin', d: 'API, database, autentikasi, payment gateway. Infrastruktur yang teruji sebelum kita tempelkan UI.', time: 'Minggu 2-3' },
          { n: 'III', t: 'Sambung Antarmuka', d: 'UI yang bersih, responsif, dan terasa premium di setiap klik. Bukan template Bootstrap.', time: 'Minggu 3-4' },
          { n: 'IV', t: 'Uji & Luncur', d: 'Squash bug, tes payment live, deploy ke production. Sistem Anda siap dipakai dari hari pertama.', time: 'Minggu 4' }
        ].map((step, i) => (
          <div class="bg-[var(--ink)] p-8 relative group">
            <div class="absolute top-6 right-6 font-mono text-[10px] uppercase tracking-wider text-[var(--paper)]/30">{step.time}</div>
            <div class="font-serif text-5xl text-[var(--gold)]/60 leading-none mb-6">{step.n}</div>
            <h3 class="font-serif text-xl text-[var(--paper)] mb-3">{step.t}</h3>
            <p class="text-sm text-[var(--paper)]/65 leading-[1.6]">{step.d}</p>
          </div>
        ))}
      </div>

      <!-- Pull quote -->
      <div class="mt-20 max-w-3xl">
        <div class="text-[var(--gold)] text-5xl font-serif leading-none mb-4">"</div>
        <p class="pull-quote text-2xl md:text-3xl text-[var(--paper)] leading-[1.25] mb-6">
          Scope yang jelas di awal adalah alasan kenapa kami selalu menyelesaikan tepat waktu. Tidak ada scope creep, tidak ada "tambahin ini dulu ya".
        </p>
        <div class="flex items-center gap-3">
          <div class="w-10 h-px bg-[var(--gold)]"></div>
          <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--paper)]/50">Prinsip kerja</span>
        </div>
      </div>
    </div>
  </section>

  <!-- =================== 04 · KARYA =================== -->
  <section id="karya" class="relative max-w-7xl mx-auto px-6 py-24 md:py-32">
    <div class="grid lg:grid-cols-12 gap-8 mb-16">
      <div class="lg:col-span-2">
        <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--ink-mute)] mb-2">Bagian</div>
        <div class="font-serif text-7xl text-[var(--emerald)] leading-none">04</div>
      </div>
      <div class="lg:col-span-10">
